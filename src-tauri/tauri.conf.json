{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Elite Trade Finder",
	"version": "0.1.7",
	"identifier": "net.stilma.elite-trade-finder",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"windows": [
			{
				"title": "Elite Trade Finder",
				"width": 1400,
				"height": 900,
				"minWidth": 1024,
				"minHeight": 700,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "nsis", "deb", "rpm", "appimage"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
